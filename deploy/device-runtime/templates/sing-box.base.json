{
  "log": {
    "level": "warn"
  },
  "inbounds": [
    {
      "type": "mixed",
      "listen": "{{SING_BOX_LISTEN_HOST}}",
      "listen_port": 1080,
      "users": [
        {
          "username": "{{RELAY_USER}}",
          "password": "{{RELAY_PASSWORD}}"
        }
      ]
    },
    {
      "type": "socks",
      "listen": "{{SING_BOX_LISTEN_HOST}}",
      "listen_port": 1081,
      "users": [
        {
          "username": "{{RELAY_USER}}",
          "password": "{{RELAY_PASSWORD}}"
        }
      ]
    },
    {
      "type": "http",
      "listen": "{{SING_BOX_LISTEN_HOST}}",
      "listen_port": 3128,
      "users": [
        {
          "username": "{{RELAY_USER}}",
          "password": "{{RELAY_PASSWORD}}"
        }
      ]
    }
  ],
  "outbounds": [
    {
      "type": "direct"
    }
  ],
  "route": {
    "default_domain_resolver": "dns-mts1"
  },
  "dns": {
    "strategy": "ipv4_only",
    "servers": [
      {
        "type": "udp",
        "tag": "dns-mts1",
        "server": "194.158.196.141",
        "server_port": 53
      },
      {
        "type": "udp",
        "tag": "dns-mts2",
        "server": "194.158.196.137",
        "server_port": 53
      },
      {
        "type": "udp",
        "tag": "dns-cf",
        "server": "1.1.1.1",
        "server_port": 53
      }
    ],
    "final": "dns-mts1"
  }
}
