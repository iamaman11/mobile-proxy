{
  "node_id": "{{NODE_ID}}",
  "node_name": "{{NODE_NAME}}",
  "listen": "127.0.0.1:8088",
  "admin_token": "{{ADMIN_TOKEN}}",
  "control_plane": {
    "base_url": "{{CONTROL_PLANE_URL}}",
    "device_token": "{{DEVICE_TOKEN}}",
    "heartbeat_interval_secs": 2,
    "poll_interval_secs": 5
  },
  "observer_urls": [
    "https://api.ipify.org?format=json"
  ],
  "proxy": {
    "binary": "/data/adb/mobile-proxy-node/current/bin/sing-box",
    "args": [
      "run",
      "-c",
      "/data/adb/mobile-proxy-node/current/config/sing-box.json"
    ],
    "working_dir": "/data/adb/mobile-proxy-node/current",
    "env": {},
    "listen_address": "{{PROXY_LISTEN_ADDRESS}}"
  },
  "wireguard": {
    "enabled": {{WIREGUARD_ENABLED}},
    "owner": "{{TUNNEL_OWNER}}",
    "up_command": "true",
    "down_command": "true"
  },
  "reverse_tunnel": {
    "enabled": {{REVERSE_TUNNEL_ENABLED}},
    "transport": "quic",
    "server_addr": "{{REVERSE_TUNNEL_ADDR}}",
    "local_proxy_addr": "127.0.0.1:1080",
    "server_name": "{{REVERSE_TUNNEL_SERVER_NAME}}",
    "server_cert_der_b64": "{{REVERSE_TUNNEL_CERT_DER_B64}}",
    "auth_token": "{{DEVICE_TOKEN}}",
    "connect_timeout_ms": 2000,
    "heartbeat_interval_ms": 2000,
    "reconnect_floor_ms": 1000,
    "reconnect_ceiling_ms": 30000
  },
  "network": {
    "cellular_only": true,
    "wifi_disable_command": "svc wifi disable",
    "status_command": "ip addr show rmnet4; ip -4 route show table all | grep -E '^default .* dev rmnet4' || true"
  },
  "rotation": {
    "drain_delay_secs": 2,
    "data_reconnect": {
      "enabled": true,
      "command": "svc data disable && sleep 20 && svc data enable"
    },
    "airplane_bounce": {
      "enabled": true,
      "command": "settings put global airplane_mode_on 1 && am broadcast -a android.intent.action.AIRPLANE_MODE --ez state true && sleep {{AIRPLANE_HOLD_SECS}} && settings put global airplane_mode_on 0 && am broadcast -a android.intent.action.AIRPLANE_MODE --ez state false"
    },
    "network_mode_bounce": {
      "enabled": true,
      "command": "settings put global preferred_network_mode1 3 && settings put global preferred_network_mode 3,9 && svc data disable && sleep 15 && svc data enable && sleep 20 && settings put global preferred_network_mode1 9 && settings put global preferred_network_mode 9,9 && svc data disable && sleep 15 && svc data enable"
    },
    "ril_bounce": {
      "enabled": true,
      "command": "stop ril-daemon && stop ril-daemon1 && sleep 8 && start ril-daemon && start ril-daemon1 && sleep 35"
    }
  },
  "reliability": {
    "max_restart_attempts": 5,
    "restart_window_secs": 600,
    "quarantine_secs": 900,
    "max_flaps_per_window": 6,
    "flap_window_secs": 900
  },
  "operator_detection": {
    "command": "getprop gsm.operator.numeric | tr ',' '\\n' | grep -E '^[0-9]{5,6}$' | head -n1"
  },
  "operator_profiles": {
    "default_profile": "{{OPERATOR_PROFILE}}",
    "by_plmn": {
      "25702": "mts_by",
      "25704": "life_by"
    },
    "profiles": {
      "default": {
        "preferred_rotation_strategy": "data_reconnect",
        "fallback_strategies": [
          "airplane_bounce"
        ],
        "airplane_hold_secs": 10,
        "drain_delay_secs": 2,
        "rotate_cooldown_secs": 30,
        "expect_ip_change": true,
        "sticky_after_failures": 2
      },
      "mts_by": {
        "preferred_rotation_strategy": "airplane_bounce",
        "fallback_strategies": [
          "data_reconnect",
          "network_mode_bounce"
        ],
        "airplane_hold_secs": 5,
        "drain_delay_secs": 2,
        "rotate_cooldown_secs": 20,
        "expect_ip_change": true,
        "sticky_after_failures": 2
      },
      "life_by": {
        "preferred_rotation_strategy": "airplane_bounce",
        "fallback_strategies": [
          "data_reconnect",
          "network_mode_bounce",
          "ril_bounce"
        ],
        "airplane_hold_secs": 10,
        "drain_delay_secs": 2,
        "rotate_cooldown_secs": 45,
        "expect_ip_change": false,
        "sticky_after_failures": 1
      }
    }
  }
}
